; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[Fmod]

General/banks_path="res://banks/DesktopT"
General/should_load_by_name=true

[application]

config/name="Mordekaiser"
config/features=PackedStringArray("4.5", "C#", "Mobile")
config/icon="res://icon.svg"

[debug]

settings/gdscript/always_track_call_stacks=true

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080

[dotnet]

project/assembly_name="Mordekaiser"

[editor]

export/convert_text_resources_to_binary=false

[editor_plugins]

enabled=PackedStringArray("res://addons/dev_tools/plugin.cfg", "res://addons/mega_text/plugin.cfg", "res://addons/megacontentcreator/plugin.cfg")

[importer_defaults]

texture={
"compress/channel_pack": 0,
"compress/hdr_compression": 2,
"compress/high_quality": true,
"compress/lossy_quality": 0.85,
"compress/mode": 1,
"compress/normal_map": 2,
"compress/rdo_quality_loss": 9.072,
"compress/uastc_level": 4,
"detect_3d/compress_to": 1,
"mipmaps/generate": false,
"mipmaps/limit": -1,
"process/channel_remap/alpha": 3,
"process/channel_remap/blue": 2,
"process/channel_remap/green": 1,
"process/channel_remap/red": 0,
"process/fix_alpha_border": true,
"process/hdr_as_srgb": false,
"process/hdr_clamp_exposure": false,
"process/normal_map_invert_y": false,
"process/premult_alpha": false,
"process/size_limit": 0,
"roughness/mode": 0,
"roughness/src_normal": ""
}

[rendering]

textures/vram_compression/import_s3tc_bptc=true
